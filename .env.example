# Copy to .env and fill in. M0 (EchoStrategy) needs NONE of these — they come
# online as later milestones land.

# --- Generation (M2/M3) — needed to query the agentic/graph strategies ---
ANTHROPIC_API_KEY=
# Answer model: claude-opus-4-8 (default) | claude-sonnet-4-6 | claude-haiku-4-5
ANSWER_MODEL=claude-opus-4-8
# Entity/relation extraction model used when building the graph (cheap):
EXTRACT_MODEL=claude-haiku-4-5

# --- Embeddings (M1+) — pick one provider, default is voyage ---
EMBED_PROVIDER=voyage
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- Strategies to expose (first = UI default) ---
ENABLED_STRATEGIES=echo,agentic,graph

# --- Ingestion (M1) ---
# Most-recent N episodes to ingest (0 = entire catalog). Keep small to limit disk.
EPISODE_WINDOW=30

# --- API security (set before exposing on a network) ---
# If set, /chat and /strategies require this token (Authorization: Bearer <token>
# or X-API-Key). Empty = open (dev only). Or load from a file via API_AUTH_TOKEN_FILE.
API_AUTH_TOKEN=
RATE_LIMIT_PER_MIN=120
# Secrets-manager friendly: point *_FILE at a mounted secret instead of inlining keys.
# ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key

# --- Infra ---
QDRANT_URL=http://localhost:6333
